<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rideshare.controller.LoginController"
      alignment="CENTER"
      spacing="20"
      stylesheets="@../css/style.css"
      styleClass="root"
      style="-fx-padding: 50;">

    <VBox spacing="25" alignment="CENTER" styleClass="card-panel" style="-fx-pref-width: 350;">
        <Label text="Ride Sharing Portal" styleClass="title-label" />
        <Label text="Sign in to continue your journey" styleClass="subtitle-label" style="-fx-padding: 0 0 10 0;"/>

        <VBox spacing="15" alignment="CENTER">
            <TextField fx:id="usernameField" promptText="Username" />
            <PasswordField fx:id="passwordField" promptText="Password" />
        </VBox>

        <Button text="Login" onAction="#login" styleClass="btn-primary" style="-fx-pref-width: 260; -fx-cursor: hand;" />

        <Hyperlink text="Don't have an account? Create one" onAction="#goToRegister" styleClass="hyperlink" />
    </VBox>

</VBox>