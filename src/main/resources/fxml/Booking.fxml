<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rideshare.controller.BookingFXController"
      alignment="CENTER"
      spacing="20"
      stylesheets="@../css/style.css"
      styleClass="root"
      style="-fx-padding: 40;">

    <VBox spacing="25" alignment="CENTER" styleClass="card-panel" style="-fx-pref-width: 440;">
        <Label text="Book a Ride" styleClass="title-label" />
        <Label text="Confirm your seat reservation instantly" styleClass="subtitle-label" style="-fx-padding: 0 0 10 0;"/>

        <GridPane alignment="CENTER" hgap="15" vgap="18">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" />
                <ColumnConstraints halignment="LEFT" />
            </columnConstraints>

            <Label text="Ride ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
            <TextField fx:id="rideIdField" promptText="Enter Ride ID to book" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
            <TextField fx:id="studentIdField" promptText="Your Student ID" GridPane.columnIndex="1" GridPane.rowIndex="1" disable="true" />
        </GridPane>

        <VBox spacing="14" alignment="CENTER" style="-fx-padding: 15 0 0 0;">
            <Button text="Confirm Booking" onAction="#bookRide"
                    styleClass="btn-warning" style="-fx-pref-width: 260;" />
            
            <Button text="Back to Dashboard" onAction="#goBack"
                    styleClass="btn-secondary" style="-fx-pref-width: 260;" />
        </VBox>
    </VBox>

</VBox>