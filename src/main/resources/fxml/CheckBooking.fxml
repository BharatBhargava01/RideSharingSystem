<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rideshare.controller.CheckBookingController"
      alignment="CENTER"
      spacing="20"
      stylesheets="@../css/style.css"
      styleClass="root"
      style="-fx-padding: 30 40 40 40;">

    <VBox spacing="25" alignment="CENTER" styleClass="card-panel" style="-fx-pref-width: 480;">
        <Label text="Track Your Booking" styleClass="title-label" />
        <Label text="Verify seat reservation details using your confirmation ID" styleClass="subtitle-label" style="-fx-padding: 0 0 10 0;"/>

        <HBox spacing="12" alignment="CENTER" style="-fx-pref-width: 420;">
            <TextField fx:id="confirmationIdField" promptText="Enter Confirmation ID (e.g. RS-A1B2C3D4)" style="-fx-pref-width: 280;"/>
            <Button text="Search" onAction="#checkBookingStatus" styleClass="btn-info" style="-fx-pref-width: 100;" />
        </HBox>

        <!-- Dynamic Results Panel -->
        <VBox fx:id="resultsBox" spacing="15" alignment="CENTER" managed="false" visible="false"
              style="-fx-background-color: #1a1c23; -fx-background-radius: 10; -fx-padding: 20; -fx-border-color: #2d3748; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-pref-width: 420;">
            
            <Label text="Booking Found" style="-fx-text-fill: #48bb78; -fx-font-weight: bold; -fx-font-size: 16px;"/>
            
            <GridPane hgap="15" vgap="10" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" prefWidth="130"/>
                    <ColumnConstraints halignment="LEFT" prefWidth="210"/>
                </columnConstraints>

                <Label text="Confirmation ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #a0aec0;"/>
                <Label fx:id="confirmIdLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #f7fafc;"/>

                <Label text="Ride details:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #a0aec0;"/>
                <Label fx:id="rideDetailsLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #00f2fe;"/>

                <Label text="Ride ID:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #a0aec0;"/>
                <Label fx:id="rideIdLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-text-fill: #e4e6eb;"/>

                <Label text="Driver ID:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-text-fill: #a0aec0;"/>
                <Label fx:id="driverIdLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-text-fill: #e4e6eb;"/>

                <Label text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-text-fill: #a0aec0;"/>
                <Label fx:id="studentIdLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-text-fill: #e4e6eb;"/>

                <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-text-fill: #a0aec0;"/>
                <Label fx:id="statusLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-text-fill: #48bb78;"/>
            </GridPane>
        </VBox>

        <VBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
            <Button text="Back to Dashboard" onAction="#goBack"
                    styleClass="btn-secondary" style="-fx-pref-width: 260;" />
        </VBox>
    </VBox>

</VBox>
